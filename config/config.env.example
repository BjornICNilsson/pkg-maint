# pkg-maint configuration example
# Copy to: ~/.config/pkg-maint/config.env

# Space-separated package names to hold back from upgrades.
PIP_EXCLUDE=""
UV_EXCLUDE=""
NPM_EXCLUDE=""

# Override package manager commands if needed.
PIP_CMD="python3 -m pip"
UV_CMD="uv"
NPM_CMD="npm"

# History log destination.
LOG_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/pkg-maint/history.log"
